generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id          String   @id @default(uuid())
  pageName    String
  language    String
  jsonContent Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pageName, language])
}
