generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PageContent {
  id          String    @id @default(uuid())
  page        String
  language    String
  title       String
  subtitle    String?
  description String
  image       String?
  video       String?
  jsonContent Json
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([page, language])
}

model Article {
  id            String       @id @default(uuid())
  language      String
  title         String
  subtitle      String
  image         String
  jsonContent   Json
  pageContentId String?
  pageContent   PageContent? @relation(fields: [pageContentId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model CoopItem {
  id          String   @id @default(uuid())
  language    String
  address     String
  name        String
  description String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
