generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PageContent {
  id          String   @id @default(uuid())
  page        String   @unique
  language    String
  title       String
  subtitle    String?
  description String
  image       String?
  video       String?
  jsonContent Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id          String   @id @default(uuid())
  title       String
  subtitle    String
  image       String
  jsonContent Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CoopItem {
  id          String   @id @default(uuid())
  address     String
  name        String
  description String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
