generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id          String   @id @default(uuid())
  pageName    String
  language    String
  jsonContent Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pageName, language])
}

model PageContent {
  id          String   @id @default(uuid())
  page        String
  language    String
  title       String
  subtitle    String?
  description String
  image       String?
  video       String?
  jsonContent Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([page, language])
}
